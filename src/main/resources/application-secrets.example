# ============================================================================
# EJEMPLO DE CONFIGURACION DE SECRETOS
# ============================================================================
# Copia este archivo a application-secrets.properties
# Reemplaza los valores con tus credenciales reales
# 
# Comando:
#   cp src/main/resources/application-secrets.example \
#      src/main/resources/application-secrets.properties

# MySQL
spring.datasource.mysql.password=your_mysql_password
spring.datasource.username=your_username

# SQL Server
spring.datasource.sqlserver.password=your_sqlserver_password

# Otros secretos (opcional)
# spring.security.jwt.secret=your_jwt_secret_key
# spring.mail.password=your_email_password
# app.api.key=your_api_key
